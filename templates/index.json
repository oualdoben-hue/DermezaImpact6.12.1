    "trustpilot_section_fkWDPH": {
      "type": "trustpilot-section",
      "blocks": {
        "review_XNH77b": {
          "type": "review",
          "settings": {
            "author": "Camille – Paris 🇫🇷",
            "date": "Une révélation dans ma routine beauté.",
            "review_text": "Je suis habituellement très exigeante avec les soins que j’utilise. J’ai testé plusieurs solutions pour ralentir la repousse, sans réel résultat durable.\nAprès plusieurs semaines avec Dermeza, j’ai constaté une repousse visiblement plus lente et des poils plus fins. La différence est progressive, mais bien réelle.\nAujourd’hui, je peux espacer mes épilations et ma peau reste douce beaucoup plus longtemps",
            "rating": 5,
            "show_verified": true,
            "verified_text": "Avis vérifié"
          }
        },
        "review_dhAm8A": {
          "type": "review",
          "settings": {
            "author": "Nadia – Bruxelles 🇧🇪",
            "date": "Parfait pour ma peau sensible.",
            "review_text": "Ma peau est très sensible et réagit facilement aux produits cosmétiques, j’avais quelques appréhensions.\nAucune irritation, aucune rougeur. La texture est agréable et laisse la peau souple et confortable.\nEn plus de ralentir la repousse, ma peau est visiblement plus lisse",
            "rating": 5,
            "show_verified": true,
            "verified_text": "Avis vérifié"
          }
        },
        "review_qcUUnw": {
          "type": "review",
          "settings": {
            "author": "Mélissa – Genève 🇨🇭",
            "date": "Une alternative élégante au laser.",
            "review_text": "Je cherchais une solution plus douce et plus accessible que le laser.\nAprès quelques semaines d’utilisation régulière, la repousse est clairement plus lente et plus fine. Je peux espacer mes épilations sans contrainte.\nC’est une solution rassurante et efficace.",
            "rating": 5,
