<div class="image-ticker-section" style="background-color: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0; overflow: hidden;">
  <div class="image-ticker-container">
    <div class="image-ticker-track" style="animation: scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;{% if section.settings.direction == 'right' %} animation-direction: reverse;{% endif %}">
      {% for block in section.blocks %}
        <div class="image-ticker-item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="image-ticker-link">
          {% endif %}
          
          {% if block.settings.image != blank %}
            {%- assign img_height = section.settings.image_height -%}
            <img 
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.image.alt | default: 'Logo' | escape }}"
              width="auto"
              height="{{ img_height }}"
              loading="lazy"
              class="ticker-image"
            >
          {% else %}
            <div class="image-ticker-placeholder">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="#ccc">
                <path d="M34.5 29.5l-7-7-4 4-7-7-7 7v-19h25v22zm-24-24v24l7-7 7 7 4-4 7 7v-27h-25z"/>
              </svg>
            </div>
          {% endif %}
          
          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
      
      {% for block in section.blocks %}
        <div class="image-ticker-item">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="image-ticker-link">
          {% endif %}
          
          {% if block.settings.image != blank %}
            {%- assign img_height = section.settings.image_height -%}
            <img 
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.image.alt | default: 'Logo' | escape }}"
              width="auto"
              height="{{ img_height }}"
              loading="lazy"
              class="ticker-image"
            >
          {% else %}
            <div class="image-ticker-placeholder"></div>
          {% endif %}
          
          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .image-ticker-section {
    width: 100%;
    position: relative;
  }
  
  .image-ticker-container {
    overflow: hidden;
    position: relative;
    width: 100%;
  }
  
  .image-ticker-track {
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    width: fit-content;
    will-change: transform;
  }
  
  .image-ticker-track:hover {
    animation-play-state: paused;
  }
  
  .image-ticker-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ticker-image {
    height: {{ section.settings.image_height }}px;
    width: auto;
    object-fit: contain;
    display: block;
    max-width: 100%;
  }
  
  .image-ticker-placeholder {
    height: {{ section.settings.image_height }}px;
    width: {{ section.settings.image_height }}px;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .image-ticker-link {
    display: block;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .image-ticker-link:hover {
    opacity: 0.8;
    transform: scale(1.05);
  }
  
  @keyframes scroll-{{ section.id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  
  @media (max-width: 768px) {
    .image-ticker-track {
      gap: calc({{ section.settings.gap }}px / 2);
    }
    
    .ticker-image {
      height: calc({{ section.settings.image_height }}px * 0.7);
    }
    
    .image-ticker-placeholder {
      height: calc({{ section.settings.image_height }}px * 0.7);
      width: calc({{ section.settings.image_height }}px * 0.7);
    }
  }
</style>

{% schema %}
{
  "name": "Ticker Images",
  "settings": [
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Hauteur des images",
      "default": 80
    },
    {
      "type": "range",
      "id": "gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Espacement entre images",
      "default": 60
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Vitesse de défilement",
      "default": 30,
      "info": "Plus le nombre est élevé, plus c'est lent"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        {
          "value": "left",
          "label": "Droite vers gauche"
        },
        {
          "value": "right",
          "label": "Gauche vers droite"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacement haut",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacement bas",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommandé : PNG avec fond transparent"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Images",
      "category": "Custom",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
